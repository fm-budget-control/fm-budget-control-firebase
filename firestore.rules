rules_version = '2';

// Firestore is server-only: all reads and writes go through Cloud Functions
// using the Admin SDK, which bypasses these rules entirely. This file exists
// to make that boundary explicit and to deny any future direct client access
// by default, rather than leaving it to Firebase's undocumented default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
